#!/usr/bin/env bash
set -Eeuo pipefail

ENV_FILE="/etc/spider-bridge/config.env"
SQUID_CONF="/etc/squid/squid.conf"
SQUID_USERS="/etc/squid/spider_bridge_users"
GOST_SERVICE="/etc/systemd/system/spider-bridge-proxy.service"
GOST_BIN="/usr/local/bin/gost"

die() {
  printf 'ERROR: %s\n' "$*" >&2
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || die "Missing command: $1"
}

validate_token() {
  local name="$1"
  local value="$2"
  [[ -n "$value" ]] || die "$name cannot be empty"
  [[ "$value" != *[[:space:]]* ]] || die "$name cannot contain whitespace"
}

validate_local_credential() {
  local name="$1"
  local value="$2"
  [[ "$value" =~ ^[A-Za-z0-9._-]{3,64}$ ]] || die "$name must be 3-64 chars: A-Z a-z 0-9 . _ -"
}

validate_port() {
  local value="$1"
  [[ "$value" =~ ^[0-9]+$ ]] || die "LOCAL_PROXY_PORT must be numeric"
  (( value >= 1 && value <= 65535 )) || die "LOCAL_PROXY_PORT must be between 1 and 65535"
}

validate_country() {
  local value="$1"
  [[ -z "$value" || "$value" =~ ^[A-Z]{2}$ ]] || die "SPIDER_COUNTRY_CODE must be empty or a 2-letter ISO country code"
}

validate_country_param() {
  local value="$1"
  case "$value" in
    country|country_code) ;;
    *) die "SPIDER_COUNTRY_PARAM must be country_code or country" ;;
  esac
}

validate_bridge_engine() {
  local value="$1"
  case "$value" in
    squid|gost) ;;
    *) die "BRIDGE_ENGINE must be squid or gost" ;;
  esac
}

validate_upstream_scheme() {
  local value="$1"
  case "$value" in
    http|https|socks5) ;;
    *) die "SPIDER_UPSTREAM_SCHEME must be http, https, or socks5" ;;
  esac
}

validate_engine_upstream_pair() {
  if [[ "$BRIDGE_ENGINE" == "squid" && "$SPIDER_UPSTREAM_SCHEME" == "socks5" ]]; then
    die "Squid engine cannot use socks5 upstream. Use BRIDGE_ENGINE=gost for Spider SOCKS5."
  fi
}

default_upstream_port() {
  case "$1" in
    https) printf '8889\n' ;;
    socks5) printf '8887\n' ;;
    *) printf '8888\n' ;;
  esac
}

validate_proxy_type() {
  local value="$1"
  case "$value" in
    residential|residential_static|residential_fast|residential_core|residential_plus|residential_premium|mobile|isp|datacenter) ;;
    *) die "Unsupported SPIDER_PROXY_TYPE: $value" ;;
  esac
}

validate_extra_params() {
  local value="$1"
  [[ "$value" != *[[:space:]]* ]] || die "SPIDER_EXTRA_PARAMS cannot contain whitespace"
}

load_env() {
  [[ -r "$ENV_FILE" ]] || die "Config file not found: $ENV_FILE"
  local key value
  while IFS='=' read -r key value || [[ -n "$key" ]]; do
    [[ -n "$key" && "$key" != \#* ]] || continue
    case "$key" in
      BRIDGE_ENGINE|SPIDER_API_KEY|SPIDER_PROXY_TYPE|SPIDER_COUNTRY_CODE|SPIDER_COUNTRY_PARAM|SPIDER_EXTRA_PARAMS|SPIDER_UPSTREAM_SCHEME|SPIDER_UPSTREAM_HOST|SPIDER_UPSTREAM_PORT|LOCAL_PROXY_USER|LOCAL_PROXY_PASS|LOCAL_PROXY_PORT)
        printf -v "$key" '%s' "$value"
        ;;
    esac
  done <"$ENV_FILE"
}

backup_squid_conf_once() {
  [[ -f "$SQUID_CONF" ]] || return 0
  if grep -q "Managed by spider-bridge" "$SQUID_CONF"; then
    return 0
  fi

  local backup="${SQUID_CONF}.pre-spider-bridge.$(date +%Y%m%d%H%M%S)"
  cp "$SQUID_CONF" "$backup"
  printf 'Backed up existing Squid config to %s\n' "$backup"
}

write_htpasswd() {
  install -d -m 0755 "$(dirname "$SQUID_USERS")"
  htpasswd -bcm "$SQUID_USERS" "$LOCAL_PROXY_USER" "$LOCAL_PROXY_PASS" >/dev/null

  if getent group proxy >/dev/null 2>&1; then
    chown root:proxy "$SQUID_USERS"
    chmod 0640 "$SQUID_USERS"
  else
    chmod 0644 "$SQUID_USERS"
  fi
}

build_upstream_password() {
  local password="proxy=${SPIDER_PROXY_TYPE}"

  if [[ -n "${SPIDER_COUNTRY_CODE:-}" ]]; then
    local country_value="$SPIDER_COUNTRY_CODE"
    if [[ "${SPIDER_COUNTRY_PARAM:-country_code}" == "country" ]]; then
      country_value="${country_value,,}"
    fi
    password="${password}&${SPIDER_COUNTRY_PARAM:-country_code}=${country_value}"
  fi

  if [[ -n "${SPIDER_EXTRA_PARAMS:-}" ]]; then
    password="${password}&${SPIDER_EXTRA_PARAMS}"
  fi

  printf '%s' "$password"
}

urlencode_component() {
  python3 -c 'import sys, urllib.parse; print(urllib.parse.quote(sys.argv[1], safe=""))' "$1"
}

systemd_escape_percent() {
  printf '%s' "$1" | sed 's/%/%%/g'
}

managed_squid_conf() {
  [[ -f "$SQUID_CONF" ]] && grep -q "Managed by spider-bridge" "$SQUID_CONF"
}

stop_gost_service() {
  if systemctl list-unit-files spider-bridge-proxy.service >/dev/null 2>&1 || [[ -f "$GOST_SERVICE" ]]; then
    systemctl stop spider-bridge-proxy.service >/dev/null 2>&1 || true
    systemctl disable spider-bridge-proxy.service >/dev/null 2>&1 || true
  fi
}

stop_managed_squid() {
  managed_squid_conf || return 0
  systemctl stop squid >/dev/null 2>&1 || true
  systemctl disable squid >/dev/null 2>&1 || true
}

write_squid_conf() {
  local upstream_password="$1"
  local upstream_scheme="${SPIDER_UPSTREAM_SCHEME:-http}"
  local upstream_host="${SPIDER_UPSTREAM_HOST:-proxy.spider.cloud}"
  local upstream_port="${SPIDER_UPSTREAM_PORT:-}"
  local upstream_tls_option=""

  if [[ -z "$upstream_port" ]]; then
    if [[ "$upstream_scheme" == "https" ]]; then
      upstream_port="8889"
    else
      upstream_port="8888"
    fi
  fi

  if [[ "$upstream_scheme" == "https" ]]; then
    upstream_tls_option=" tls"
  fi

  backup_squid_conf_once

  cat >"$SQUID_CONF" <<EOF
# Managed by spider-bridge. Manual edits may be overwritten.
visible_hostname spider-bridge

http_port 0.0.0.0:${LOCAL_PROXY_PORT}

auth_param basic program /usr/lib/squid/basic_ncsa_auth ${SQUID_USERS}
auth_param basic realm Spider Bridge Proxy
acl authenticated proxy_auth REQUIRED

acl SSL_ports port 443 563 8443
acl Safe_ports port 80
acl Safe_ports port 443
acl Safe_ports port 563
acl Safe_ports port 1025-65535
acl CONNECT method CONNECT

http_access deny !Safe_ports
http_access deny CONNECT !SSL_ports
http_access allow authenticated
http_access deny all

cache deny all
cache_mem 64 MB
maximum_object_size 0 KB
access_log /var/log/squid/access.log squid
cache_log /var/log/squid/cache.log
cache_store_log none
forwarded_for delete

cache_peer ${upstream_host} parent ${upstream_port} 0 no-query no-digest no-netdb-exchange default login=${SPIDER_API_KEY}:${upstream_password} name=spidercloud${upstream_tls_option}
never_direct allow all
EOF
}

write_gost_service() {
  local upstream_password="$1"
  local upstream_scheme="${SPIDER_UPSTREAM_SCHEME:-socks5}"
  local upstream_host="${SPIDER_UPSTREAM_HOST:-proxy.spider.cloud}"
  local upstream_port="${SPIDER_UPSTREAM_PORT:-}"

  if [[ -z "$upstream_port" ]]; then
    upstream_port="$(default_upstream_port "$upstream_scheme")"
  fi

  local local_user local_pass spider_user spider_pass local_url upstream_url
  local systemd_local_url systemd_upstream_url
  local_user="$(urlencode_component "$LOCAL_PROXY_USER")"
  local_pass="$(urlencode_component "$LOCAL_PROXY_PASS")"
  spider_user="$(urlencode_component "$SPIDER_API_KEY")"
  spider_pass="$(urlencode_component "$upstream_password")"
  local_url="http://${local_user}:${local_pass}@0.0.0.0:${LOCAL_PROXY_PORT}"
  upstream_url="${upstream_scheme}://${spider_user}:${spider_pass}@${upstream_host}:${upstream_port}"
  systemd_local_url="$(systemd_escape_percent "$local_url")"
  systemd_upstream_url="$(systemd_escape_percent "$upstream_url")"

  cat >"$GOST_SERVICE" <<EOF
[Unit]
Description=Spider Bridge Proxy (GOST)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=${GOST_BIN} -L ${systemd_local_url} -F ${systemd_upstream_url}
Restart=always
RestartSec=3
User=root
NoNewPrivileges=true
PrivateTmp=true
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
EOF
}

ensure_no_via_off() {
  if grep -Eq '^[[:space:]]*via[[:space:]]+off([[:space:]]|$)' "$SQUID_CONF"; then
    die "Squid config still contains 'via off'. Reinstall the latest spider-bridge files and run apply again."
  fi
}

main() {
  require_command systemctl

  load_env

  : "${BRIDGE_ENGINE:=squid}"
  : "${SPIDER_API_KEY:?SPIDER_API_KEY is required}"
  : "${LOCAL_PROXY_USER:?LOCAL_PROXY_USER is required}"
  : "${LOCAL_PROXY_PASS:?LOCAL_PROXY_PASS is required}"
  : "${LOCAL_PROXY_PORT:=3128}"
  : "${SPIDER_PROXY_TYPE:=residential}"
  : "${SPIDER_COUNTRY_CODE:=US}"
  : "${SPIDER_COUNTRY_PARAM:=country_code}"
  : "${SPIDER_EXTRA_PARAMS:=}"
  if [[ -z "${SPIDER_UPSTREAM_SCHEME:-}" ]]; then
    if [[ "$BRIDGE_ENGINE" == "gost" ]]; then
      SPIDER_UPSTREAM_SCHEME="socks5"
    else
      SPIDER_UPSTREAM_SCHEME="http"
    fi
  fi

  BRIDGE_ENGINE="${BRIDGE_ENGINE,,}"
  SPIDER_UPSTREAM_SCHEME="${SPIDER_UPSTREAM_SCHEME,,}"

  validate_token "SPIDER_API_KEY" "$SPIDER_API_KEY"
  validate_local_credential "LOCAL_PROXY_USER" "$LOCAL_PROXY_USER"
  validate_local_credential "LOCAL_PROXY_PASS" "$LOCAL_PROXY_PASS"
  validate_port "$LOCAL_PROXY_PORT"
  validate_bridge_engine "$BRIDGE_ENGINE"
  validate_proxy_type "$SPIDER_PROXY_TYPE"
  validate_country "$SPIDER_COUNTRY_CODE"
  validate_country_param "$SPIDER_COUNTRY_PARAM"
  validate_upstream_scheme "$SPIDER_UPSTREAM_SCHEME"
  validate_engine_upstream_pair
  if [[ -n "${SPIDER_UPSTREAM_PORT:-}" ]]; then
    validate_port "$SPIDER_UPSTREAM_PORT"
  fi
  validate_extra_params "$SPIDER_EXTRA_PARAMS"

  local upstream_password
  local effective_upstream_port
  upstream_password="$(build_upstream_password)"
  effective_upstream_port="${SPIDER_UPSTREAM_PORT:-}"
  if [[ -z "$effective_upstream_port" ]]; then
    effective_upstream_port="$(default_upstream_port "$SPIDER_UPSTREAM_SCHEME")"
  fi

  if [[ "$BRIDGE_ENGINE" == "gost" ]]; then
    require_command python3
    [[ -x "$GOST_BIN" ]] || die "Missing GOST binary: $GOST_BIN. Re-run installer with --bridge-engine gost."

    stop_managed_squid
    write_gost_service "$upstream_password"
    systemctl daemon-reload
    systemctl enable spider-bridge-proxy.service >/dev/null
    systemctl restart spider-bridge-proxy.service
  else
    require_command htpasswd
    require_command squid

    stop_gost_service
    write_htpasswd
    write_squid_conf "$upstream_password"
    ensure_no_via_off

    squid -k parse >/dev/null
    systemctl daemon-reload
    systemctl enable squid >/dev/null
    systemctl restart squid
  fi

  printf 'Spider bridge applied: engine %s, local port %s, pool %s, country %s, upstream %s:%s (%s)\n' \
    "$BRIDGE_ENGINE" \
    "$LOCAL_PROXY_PORT" \
    "$SPIDER_PROXY_TYPE" \
    "${SPIDER_COUNTRY_CODE:-default}" \
    "${SPIDER_UPSTREAM_HOST:-proxy.spider.cloud}" \
    "$effective_upstream_port" \
    "$SPIDER_UPSTREAM_SCHEME"
}

main "$@"
